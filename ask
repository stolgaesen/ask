#!/bin/bash

# 1. Checks whether passwords and settings are entered into the system
if [[ -z "$ASK_API_URL" || -z "$ASK_MODEL" || -z "$ASK_API_KEY" ]]; then
    echo "Error: Please set ASK_API_URL, ASK_MODEL, and ASK_API_KEY variables." >&2
    exit 1
fi

# 2. Capture the question the user asks.
USER_PROMPT=""

# Receive text from the keyboard or another command (Pipe).
if [ -p /dev/stdin ]; then
    USER_PROMPT=$(cat)
fi

# Get the text written next to the command(args)
if [ $# -gt 0 ]; then
    USER_PROMPT="$USER_PROMPT $@"
fi

# 3. Change the format to JSON
JSON_PAYLOAD=$(jq -n \
  --arg model "$ASK_MODEL" \
  --arg system_msg "You are a CLI tool. Output plain text only. No yapping. Keep the output concise." \
  --arg user_msg "$USER_PROMPT" \
  '{
    model: $model,
    messages: [
      {role: "system", content: $system_msg},
      {role: "user", content: $user_msg}
    ]
  }')

# 4. Connect to the server and get the answer
curl -s "$ASK_API_URL" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $ASK_API_KEY" \
  -d "$JSON_PAYLOAD" | jq -r '.choices[0].message.content'
